---
import type { GetStaticPaths } from "astro";

import Layout from '@layouts/Layout.astro';
import { projects } from '@lib/projects'
import ProjectDescription from "@components/ProjectDescription.astro";
import Badge from "@components/Badge.astro";
import Section from "@components/Section.astro";

const { slug } = Astro.params
const project = projects.find(project => project.slug === slug)

export const getStaticPaths = (() => {
  return projects.map(project => ({
    params: {
      slug: project.slug
    }
  }));
}) satisfies GetStaticPaths;
---

<Layout color="bg-gradient-to-r from-white via-slate-50 to-slate-200 dark:from-black dark:via-white/[0.05] dark:to-white/[0.08]" title={`${project?.name} | Luis Osorio`}>
  <main class="min-h-screen">
    {project && (
      <>
        <!-- Hero Section -->
        <header class="relative overflow-hidden fade-in">
          {project.image && (
            <div class="absolute inset-0 fade-in-scale">
              <img
                src={project.image}
                alt={project.name}
                class="w-full h-full object-cover"
              />
              <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/90"></div>
            </div>
          )}

          <div class="relative max-w-4xl mx-auto px-6 py-24 text-center fade-in-up">
            <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">
              {project.name}
            </h1>

            <p class="text-xl text-white/80 mb-8 max-w-2xl mx-auto">
              {project.shortDescription}
            </p>

            <!-- Action Links -->
            <div class="flex justify-center gap-4 mb-8">
              {project.link && (
                <a 
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-6 py-3 bg-white text-slate-900 rounded-lg font-medium hover:bg-slate-100 transition-all duration-200 transform hover:scale-105"
                >
                  <span class="icon-[ph--link-simple-duotone] text-xl" role="img" aria-hidden="true" />
                  Demo en Vivo
                </a>
              )}

              {project.repository && (
                <a 
                  href={project.repository}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-6 py-3 bg-slate-800/80 text-white rounded-lg font-medium hover:bg-slate-700/80 transition-all duration-200 transform hover:scale-105 backdrop-blur-sm"
                >
                  <span class="icon-[mdi--github] text-xl" role="img" aria-hidden="true" />
                  Ver Código
                </a>
              )}
            </div>
          </div>
        </header>

        <!-- Content Sections -->
        <div class="max-w-4xl mx-auto px-6 py-16">
          <!-- Tech Stack -->
          {project.technologies && project.technologies.length > 0 && (
            <Section title="Tecnologías" subtitle="Tecnologías utilizadas en este proyecto" class="animate-on-scroll">
              <div class="flex flex-wrap gap-3">
                {project.technologies.map((tech, index) => (
                  <Badge variant="default" class={`fade-in-up stagger-${Math.min(index + 1, 6)}`}>{tech}</Badge>
                ))}
              </div>
            </Section>
          )}

          <!-- Overview -->
          <Section title="Descripción General" subtitle="Descripción y detalles del proyecto" class="animate-on-scroll">
            <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-8 fade-in-scale">
              <ProjectDescription project={project} />
            </div>
          </Section>

          <!-- Alert/Notice -->
          {project.alert && (
            <Section class="animate-on-scroll">
              <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-xl p-6 fade-in-up">
                <div class="flex items-start gap-3">
                  <span class="icon-[ph--info-duotone] text-blue-600 dark:text-blue-400 text-xl mt-1" role="img" aria-hidden="true" />
                  <div>
                    <h3 class="font-semibold text-blue-900 dark:text-blue-100 mb-1">Nota</h3>
                    <p class="text-blue-800 dark:text-blue-200">{project.alert}</p>
                  </div>
                </div>
              </div>
            </Section>
          )}
        </div>
      </>
    )}
  </main>

  <style>
    @import '../../styles/animations.css';
  </style>
</Layout>
