---
import Layout from '@layouts/Layout.astro';
import Project from '@components/Project.astro';

import { projects } from '@lib/projects'
---

<Layout color="bg-gradient-to-r from-white via-slate-50 to-slate-200 dark:from-black dark:via-white/[0.05] dark:to-white/[0.08]" title="Luis Osorio | luisfosg">
  <main class="max-w-7xl mx-auto px-6 py-16">
    <header class="text-center mb-16 fade-in">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white mb-4">
        Proyectos
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        Una colección curada de mi trabajo. Algunos proyectos pueden tener acceso restringido por razones de seguridad.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      { projects.map((project, index) => (
        <div class={`fade-in-up stagger-${Math.min(index + 1, 6)}`}>
          <Project project={project} />
        </div>
      )) }
    </div>
  </main>

  <style>
    @import '../../styles/animations.css';
  </style>
</Layout>
