---
interface Props {
  project: {
    name: string;
    description: string;
    features?: string[];
    architecture?: string;
  };
}

const { project } = Astro.props;
---

<div class="space-y-6">
  <div>
    <p class="text-lg leading-relaxed text-slate-700 dark:text-slate-300">
      {project.description}
    </p>
  </div>

  {project.features && project.features.length > 0 && (
    <div>
      <h3 class="text-xl font-semibold mb-3 text-slate-900 dark:text-white">Características Principales</h3>
      <ul class="list-disc pl-6 space-y-2 text-slate-600 dark:text-slate-400">
        {project.features.map(feature => (
          <li>{feature}</li>
        ))}
      </ul>
    </div>
  )}

  {project.architecture && (
    <div>
      <h3 class="text-xl font-semibold mb-3 text-slate-900 dark:text-white">Arquitectura y Desarrollo</h3>
      <p class="text-slate-600 dark:text-slate-400">{project.architecture}</p>
    </div>
  )}
</div>
